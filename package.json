{
  "name": "location-todo-api-nest",
  "version": "0.1.0",
  "private": true,
  "description": "Location Todo API, workers, and management web app",
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm run build:api && npm run build:web && node scripts/copy-assets.mjs",
    "build:api": "tsc -p tsconfig.build.json",
    "build:web": "vite build --config web/vite.config.ts",
    "db:migrate": "ts-node src/database/migrate.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src test web/src --max-warnings=0",
    "start": "node dist/main.js",
    "start:prod": "node dist/start.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "test": "jest --runInBand",
    "test:e2e": "jest --config jest-e2e.json --runInBand",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p web/tsconfig.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.9",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/platform-socket.io": "^11.1.9",
    "@nestjs/websockets": "^11.1.9",
    "jose": "^5.10.0",
    "pg": "^8.16.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@nestjs/testing": "^11.1.9",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1",
    "vite": "^7.1.7"
  }
}
