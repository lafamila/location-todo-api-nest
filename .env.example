# location-todo-api-nest — env shape canonical
# 실제 secret 값은 절대 커밋하지 않는다.

NODE_ENV=development
PORT=3042
TZ=Asia/Seoul
DATABASE_URL=postgresql://location_todo:change-me@localhost:5432/location_todo

PUBLIC_ORIGIN=http://localhost:3042
WEB_ALLOWED_ORIGINS=http://localhost:3042

AUTH_API_BASE_URL=http://localhost:3032
AUTH_ISSUER_URL=http://localhost:3032
AUTH_JWKS_URL=http://localhost:3032/.well-known/jwks.json
AUTH_AUDIENCE=service:location-todo
AUTH_SERVICE_KEY=location-todo
LOCATION_TODO_OIDC_CLIENT_ID=location-todo-api
LOCATION_TODO_OIDC_CLIENT_SECRET=
LOCATION_TODO_OIDC_REDIRECT_URI=http://localhost:3042/api/session/oidc/callback

SESSION_COOKIE_NAME=location_todo_session
SESSION_HEADER_NAME=X-Location-Todo-Session
SESSION_IDLE_TTL_SECONDS=2592000
SESSION_ABSOLUTE_TTL_SECONDS=15552000
AUTH_TOKEN_ENCRYPTION_KEY=

KAKAO_REST_API_KEY=
KAKAO_JAVASCRIPT_KEY=
KAKAO_ALLOWED_WEB_ORIGINS=http://localhost:3042

FIREBASE_PROJECT_ID=location-todo
FIREBASE_SERVICE_ACCOUNT_JSON=

OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_MAX_ATTEMPTS=12
DUE_JOB_POLL_INTERVAL_MS=1000
DEVICE_INACTIVE_RETENTION_DAYS=90
NOTIFICATION_RETENTION_DAYS=30
